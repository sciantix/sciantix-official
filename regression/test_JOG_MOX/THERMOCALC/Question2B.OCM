@$ Question 2


@$ is command removes any previous data 
@$ The echo lists the command

new Y

set echo Y

@$ path to database
@$ r t /home/ecappellari/transparant/opencalphad/data/CsMoO_TAFID_2021_Anna cs mo o

r t CsMoO_TAFID_2021_Anna
cs mo o

@$ initialize variables
set ref o gas * 100000
set c t=1140
set c p=5436000
set c mu(o)=-209944

@$ increasing the amounts ....
set c n(cs)=2.83652689
set c n(mo)=3.6708

set st ph *=dor

set st ph gas liq=e 1

c e

l r 2


@$ Again a liquid miscibility gap, add BCC
@&

set st ph bcc=e 0

c e

l r 2

@$  set all dormant phases as stable with zero amount
@&

set st ph *D = E 0

c e

l r 2

@$ The MoO2 wants to be stable 
@&

set st ph moo2=e 1

c e

l ,,,,

@$ Competition between Cs2MoO4_S1 and Cs2MoO4_S2

@&

set st ph cs2MoO4_s2=dorm

c e

l r 2


@$ it seems impossible to obtain a stable equilibrium



set inter


This seems to be the best result but the two phases Cs2MoO4_s1/s2 compete

